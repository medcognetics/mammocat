{
  "name": "@medcognetics/mammocat",
  "version": "0.2.0",
  "private": true,
  "description": "Node/TypeScript bindings for mammocat DICOM mammography metadata extraction and preferred-view selection",
  "license": "Apache-2.0",
  "main": "node/index.js",
  "types": "node/index.d.ts",
  "files": [
    "node/index.js",
    "node/index.d.ts",
    "node/*.node",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "napi build --cwd node --platform --release",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.2"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "@inquirer/prompts": "7.10.1",
    "@napi-rs/lzma": "1.4.5",
    "@octokit/rest": "21.1.1"
  }
}
