{
  "name": "@medcognetics/mammocat",
  "version": "0.2.0",
  "description": "Node/TypeScript bindings for mammocat DICOM mammography metadata extraction and preferred-view selection",
  "license": "Apache-2.0",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "LICENSE.md",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node --test test/*.test.mjs",
    "test:git-install": "node --test test/git-install.integration.mjs",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "napi artifacts --output-dir . --npm-dir npm && npm pack --dry-run && npm pack --dry-run ./npm/linux-x64-gnu"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.2",
    "@types/node": "26.1.0",
    "typescript": "6.0.3"
  },
  "optionalDependencies": {
    "@medcognetics/mammocat-darwin-arm64": "0.2.0",
    "@medcognetics/mammocat-darwin-x64": "0.2.0",
    "@medcognetics/mammocat-linux-x64-gnu": "0.2.0",
    "@medcognetics/mammocat-win32-x64-msvc": "0.2.0"
  },
  "napi": {
    "binaryName": "mammocat",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ],
    "dtsHeader": "/* auto-generated by NAPI-RS */\n/* eslint-disable */\nexport type DicomInput = { path: string } | { bytes: Uint8Array; filename?: string }\n"
  },
  "engines": {
    "node": ">=22"
  }
}
